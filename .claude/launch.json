{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Django Backend",
      "runtimeExecutable": "daphne",
      "runtimeArgs": ["-b", "0.0.0.0", "-p", "8000", "config.asgi:application"],
      "port": 8000,
      "autoPort": false,
      "cwd": "backend"
    },
    {
      "name": "React Frontend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["./node_modules/vite/bin/vite.js"],
      "port": 5173,
      "cwd": "frontend"
    }
  ]
}
